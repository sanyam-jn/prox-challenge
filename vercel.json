{
  "version": 2,
  "builds": [
    { "src": "api/index.py",  "use": "@vercel/python" },
    { "src": "public/**",     "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/chat",          "dest": "/api/index.py" },
    { "src": "/health",        "dest": "/api/index.py" },
    { "src": "^/$",            "dest": "/public/index.html" },
    { "src": "/pages/(.*)",    "dest": "/public/pages/$1" },
    { "src": "/(.*)",          "dest": "/public/$1" }
  ]
}
